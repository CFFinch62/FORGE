# Integration test: records and optionals in realistic patterns

record Point:
    x: int
    y: int

record Rect:
    x: int
    y: int
    w: int
    h: int

proc make_point(x: int, y: int) -> Point:
    return Point { x: x, y: y }

proc distance_sq(a: Point, b: Point) -> int:
    var dx: int = a.x - b.x
    var dy: int = a.y - b.y
    return dx * dx + dy * dy

proc rect_area(r: Rect) -> int:
    return r.w * r.h

proc find_in_array(arr: []int, target: int) -> ?int:
    for i in range(0, len(arr)):
        if arr[i] == target:
            return some(i)
    return none

proc main() -> void:
    # Record creation and field access
    var p1: Point = make_point(3, 4)
    var p2: Point = make_point(6, 8)
    print(p1.x)
    print(p1.y)
    print(distance_sq(p1, p2))

    # Record with computed fields
    var r: Rect = Rect { x: 0, y: 0, w: 10, h: 5 }
    print(rect_area(r))

    # Records in loops
    var total_area: int = 0
    for i in range(1, 6):
        var box: Rect = Rect { x: 0, y: 0, w: i, h: i }
        total_area += rect_area(box)
    print(total_area)

    # Optional with some/none
    var maybe: ?int = some(42)
    var nothing: ?int = none
    print(maybe or_else 0)
    print(nothing or_else -1)

    # Optional from procedure
    var data: []int = [10, 20, 30, 40, 50]
    var found: ?int = find_in_array(data, 30)
    var not_found: ?int = find_in_array(data, 99)

    if found is some:
        print("found at: " + str(found or_else -1))
    if not_found is none:
        print("not found: correct")

    # Optional in loop
    var first_even: ?int = none
    for i in range(1, 10):
        if i % 2 == 0:
            if first_even is none:
                first_even = some(i)
    print(first_even or_else 0)

    # Chained or_else
    var a: ?int = none
    var b: ?int = none
    var c: ?int = some(77)
    var result: int = a or_else (b or_else (c or_else 0))
    print(result)

