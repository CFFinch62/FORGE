# Test for loops

proc main() -> void:
    # Basic for loop with range
    print("Range 0 to 5:")
    for i in range(0, 5):
        print(i)           # 0, 1, 2, 3, 4

    # Different range
    print("Range 1 to 4:")
    for i in range(1, 4):
        print(i)           # 1, 2, 3

    # Nested for loops
    print("Multiplication table 3x3:")
    for i in range(1, 4):
        for j in range(1, 4):
            print(i * j)   # 1,2,3,2,4,6,3,6,9

    # For with break
    print("Break at 3:")
    for i in range(0, 10):
        if i == 3:
            break
        print(i)           # 0, 1, 2

    # For with continue
    print("Skip 2:")
    for i in range(0, 5):
        if i == 2:
            continue
        print(i)           # 0, 1, 3, 4

    # Sum using for loop
    var sum: int = 0
    for i in range(1, 11):
        sum = sum + i
    print(sum)             # 55 (1+2+...+10)

